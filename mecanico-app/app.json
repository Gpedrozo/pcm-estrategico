{
  "expo": {
    "name": "Mecânico Industrial",
    "slug": "mecanico-industrial",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pcm.mecanico"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A2E"
      },
      "package": "com.pcm.mecanico",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        { "cameraPermission": "Necessário para escanear QR Code dos equipamentos." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Necessário para anexar fotos às execuções." }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Necessário para transcrever voz em texto nos campos.",
          "speechRecognitionPermission": "Necessário para reconhecimento de voz."
        }
      ]
    ]
  }
}
